# LLM Provider Configuration
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Alternative LLM providers (commented out for now)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# News and Content Sources
NEWSAPI_KEY=your_newsapi_key_here
GITHUB_TOKEN=your_github_token_here
RSS_FEEDS=https://news.ycombinator.com/rss,https://feeds.arstechnica.com/arstechnica/index

# Digest Configuration
DIGEST_TOPIC=Technology,Artificial Intelligence
DIGEST_TIME=07:00
DIGEST_TZ=Asia/Jakarta
MAX_ARTICLES=20
MAX_RETRIES=2
MAX_RUN_SECONDS=300

# Cost and Budget Controls
COST_LIMIT_USD=0.05
TOKEN_BUDGET=10000

# Google Drive Configuration
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Runtime Configuration
RUN_MODE=scheduler
OUTPUT_FORMAT=pdf
DATA_DIR=/app/data
LOG_LEVEL=INFO
STRICT_PDF_ONLY=true
STRICT_PDF_ALLOW_LOCAL_DEBUG_FALLBACK=false

# Development/Debug
DEBUG=False
